{
  "expo": {
    "name": "Flixify",
    "slug": "flixifyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#030303"
    },
    "android": {
      "package": "com.flixify.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "scheme": "flixify"
  }
}
