        "backgroundColor": "#030303"
      },
      "package": "com.flixify.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "scheme": "flixify",
    "extra": {
      "eas": {
        "projectId": "b771a6b0-317c-47e6-a38b-6981eac7171b"
      }
    }
  }
}
